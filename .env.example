# Copy to .env and fill in. See README for setup.

# ── Database ──────────────────────────────────────────────
# Option A — local Docker Postgres (docker compose up -d):
DATABASE_URL="postgresql://ops_admin:ops_dev_password@localhost:5432/ops_fusion"
# Option B — hosted (Neon / Supabase):
# DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"

# ── Auth.js ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Google OAuth (create at https://console.cloud.google.com/apis/credentials
# with redirect URI http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Notifications (optional) ──────────────────────────────
# Leave unset to disable email sending (portal/quote events are still logged).
# SMTP_URL="smtp://user:password@smtp.example.com:587"
# MAIL_FROM="OPS Fusion <no-reply@example.com>"
# NOTIFY_EMAIL="staff-inbox@example.com"
