# Copy to .env and fill in. See README for setup.

# ── Database ──────────────────────────────────────────────
# Option A — local Docker Postgres (docker compose up -d):
DATABASE_URL="postgresql://ops_admin:ops_dev_password@localhost:5432/ops_enterprise"
# Option B — hosted (Neon / Supabase):
# DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"

# ── Auth.js ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Google OAuth (create at https://console.cloud.google.com/apis/credentials
# with redirect URI http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
