// ============================================================
// Ops Enterprise System — unified ERP schema (v1)
// Unifies: JOWebApp (job orders), SignQuote (quotations),
// Sales-Audit (sales/reconciliation) + new DR module.
//
// Conventions:
// - Money: Decimal(12,2). Never Float.
// - Business records: soft delete via deletedAt + createdById.
// - Every FK / status / filter-date column is indexed.
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  MANAGER // ≈ Branch Supervisor
  ENCODER // ≈ Sales / Cashier
  AUDITOR
  VIEWER
}

// Placeholder classification — real client rules pending (spec 2.2 table missing).
enum CustomerType {
  TYPE_A
  TYPE_B
  TYPE_C
}

enum InquiryMedium {
  MESSENGER
  EMAIL
  WALK_IN
  CALL
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

// How the customer confirmed the quote (JO approval precondition, spec 1.2 step 2.1)
enum ConfirmationType {
  PO
  SIGNED_QUOTE
  EMAIL
}

enum JobOrderStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  IN_PROGRESS
  COMPLETED
  INVOICED
  CANCELLED
}

enum BookletType {
  SI_VAT
  SI_NON_VAT
  JO_SLIP
  CR
  DR
}

enum BookletStatus {
  PENDING_APPROVAL
  ACTIVE
  CLOSED
}

enum SaleType {
  SI_VAT
  SI_NON_VAT
}

enum PaymentMethod {
  CASH
  CHECK
  GCASH
  BANK_TRANSFER
  QR
}

enum AdvancePaymentStatus {
  UNAPPLIED
  PARTIALLY_APPLIED
  FULLY_APPLIED
}

enum DeliveryReceiptStatus {
  ISSUED
  CANCELLED
}

enum AuditEntryStatus {
  REVIEWED
  FLAGGED
}

enum AuditFlagType {
  DISCREPANCY
  MISSING
  CANCELLED
}

enum ReconDayStatus {
  NOT_STARTED
  IN_PROGRESS
  FLAGGED
  CLOSED
}

// ============================================================
// AUTH / USERS
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for OAuth-only users
  role          Role      @default(VIEWER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]

  customersCreated   Customer[]                  @relation("CustomerCreatedBy")
  productsCreated    Product[]                   @relation("ProductCreatedBy")
  inquiriesCreated   Inquiry[]                   @relation("InquiryCreatedBy")
  quotationsCreated  Quotation[]                 @relation("QuotationCreatedBy")
  quotationsApproved Quotation[]                 @relation("QuotationApprovedBy")
  jobOrdersCreated   JobOrder[]                  @relation("JobOrderCreatedBy")
  jobOrdersApproved  JobOrder[]                  @relation("JobOrderApprovedBy")
  joStatusChanges    JobOrderStatusHistory[]     @relation("JoStatusChangedBy")
  bookletsOpened     Booklet[]                   @relation("BookletOpenedBy")
  bookletsApproved   Booklet[]                   @relation("BookletApprovedBy")
  salesCreated       Sale[]                      @relation("SaleCreatedBy")
  crsCreated         CollectionReceipt[]         @relation("CrCreatedBy")
  apsCreated         AdvancePayment[]            @relation("ApCreatedBy")
  apApplications     AdvancePaymentApplication[] @relation("ApAppliedBy")
  drsCreated         DeliveryReceipt[]           @relation("DrCreatedBy")
  auditEntries       AuditEntry[]                @relation("AuditEntryAuditor")
  reconDaysLocked    ReconciliationDay[]         @relation("ReconLockedBy")
  activityLogs       ActivityLog[]
}

// Auth.js OAuth account linking (Google)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================================
// SHARED MASTERS
// ============================================================

model Customer {
  id            String       @id @default(cuid())
  name          String
  contactNumber String?
  company       String?
  email         String?
  address       String?
  tin           String?
  customerType  CustomerType @default(TYPE_C)
  vatRegistered Boolean      @default(false)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  createdById   String
  createdBy     User         @relation("CustomerCreatedBy", fields: [createdById], references: [id])

  inquiries          Inquiry[]
  quotations         Quotation[]
  jobOrders          JobOrder[]
  sales              Sale[]
  collectionReceipts CollectionReceipt[]
  advancePayments    AdvancePayment[]
  deliveryReceipts   DeliveryReceipt[]

  @@index([name])
  @@index([customerType])
  @@index([deletedAt])
  @@index([createdById])
}

model Product {
  id          String    @id @default(cuid())
  name        String
  // Free-text service category (Tarpaulin, Photocopy, Laminate, ...) —
  // client's category list still unconfirmed; maps to production workflows later.
  category    String
  unit        String    @default("pcs")
  basePrice   Decimal   @default(0) @db.Decimal(12, 2)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String
  createdBy   User      @relation("ProductCreatedBy", fields: [createdById], references: [id])

  quotationItems QuotationItem[]
  jobOrderItems  JobOrderItem[]

  @@index([name])
  @@index([category])
  @@index([isActive])
  @@index([deletedAt])
  @@index([createdById])
}

// ============================================================
// QUOTATIONS (QJOS)
// ============================================================

// Spec 1.2 Step 1 — inquiry log (Type A JOs start here)
model Inquiry {
  id                String        @id @default(cuid())
  customerId        String?
  customer          Customer?     @relation(fields: [customerId], references: [id])
  customerName      String
  contactNumber     String?
  medium            InquiryMedium
  servicesRequested String
  notes             String?
  quotationId       String?       @unique
  quotation         Quotation?    @relation(fields: [quotationId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdById       String
  createdBy         User          @relation("InquiryCreatedBy", fields: [createdById], references: [id])

  @@index([customerId])
  @@index([medium])
  @@index([createdAt])
  @@index([createdById])
}

model Quotation {
  id             String          @id @default(cuid())
  quoteNumber    String          @unique
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  status         QuotationStatus @default(DRAFT)
  validUntil     DateTime?
  subtotal       Decimal         @default(0) @db.Decimal(12, 2)
  discount       Decimal         @default(0) @db.Decimal(12, 2)
  total          Decimal         @default(0) @db.Decimal(12, 2)
  notes          String?
  sentAt         DateTime?
  approvedById   String?
  approvedBy     User?           @relation("QuotationApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  createdById    String
  createdBy      User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])

  items    QuotationItem[]
  jobOrder JobOrder? // 1—0..1 conversion link
  inquiry  Inquiry?

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([approvedById])
  @@index([createdById])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  description String
  specs       Json? // size, material, color, etc. — varies per product type
  qty         Int
  unitPrice   Decimal   @db.Decimal(12, 2)
  discount    Decimal   @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal   @db.Decimal(12, 2)
  sortOrder   Int       @default(0)

  @@index([quotationId])
  @@index([productId])
}

// ============================================================
// JOB ORDERS
// ============================================================

model JobOrder {
  id               String            @id @default(cuid())
  joNumber         String            @unique
  customerId       String
  customer         Customer          @relation(fields: [customerId], references: [id])
  quotationId      String?           @unique
  quotation        Quotation?        @relation(fields: [quotationId], references: [id])
  status           JobOrderStatus    @default(DRAFT)
  deadline         DateTime?
  isLFP            Boolean           @default(false) // LFP JOs print 3 copies (spec 1.2 step 3)
  confirmationType ConfirmationType? // how customer confirmed (approval precondition)
  subtotal         Decimal           @default(0) @db.Decimal(12, 2)
  total            Decimal           @default(0) @db.Decimal(12, 2)
  notes            String?
  approvedById     String?
  approvedBy       User?             @relation("JobOrderApprovedBy", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  createdById      String
  createdBy        User              @relation("JobOrderCreatedBy", fields: [createdById], references: [id])

  items            JobOrderItem[]
  statusHistory    JobOrderStatusHistory[]
  sale             Sale?
  deliveryReceipts DeliveryReceipt[]
  apApplications   AdvancePaymentApplication[]

  @@index([customerId])
  @@index([status])
  @@index([deadline])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([approvedById])
  @@index([createdById])
}

model JobOrderItem {
  id           String   @id @default(cuid())
  jobOrderId   String
  jobOrder     JobOrder @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  description  String
  specs        Json?
  qty          Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  qtyDelivered Int      @default(0) // maintained by DR issuance (partial delivery)
  sortOrder    Int      @default(0)

  drLines DeliveryReceiptLine[]

  @@index([jobOrderId])
  @@index([productId])
}

model JobOrderStatusHistory {
  id          String          @id @default(cuid())
  jobOrderId  String
  jobOrder    JobOrder        @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)
  fromStatus  JobOrderStatus?
  toStatus    JobOrderStatus
  remarks     String?
  changedById String
  changedBy   User            @relation("JoStatusChangedBy", fields: [changedById], references: [id])
  createdAt   DateTime        @default(now())

  @@index([jobOrderId])
  @@index([changedById])
}

// ============================================================
// SALES / AUDIT
// ============================================================

// One numbering pattern shared by SI / JO Slip / CR / DR booklets,
// with approval-on-opening (spec 3.1, 4).
model Booklet {
  id           String        @id @default(cuid())
  type         BookletType
  seriesStart  Int
  seriesEnd    Int
  nextNumber   Int
  status       BookletStatus @default(PENDING_APPROVAL)
  openedById   String
  openedBy     User          @relation("BookletOpenedBy", fields: [openedById], references: [id])
  approvedById String?
  approvedBy   User?         @relation("BookletApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sales              Sale[]
  collectionReceipts CollectionReceipt[]
  deliveryReceipts   DeliveryReceipt[]

  @@index([type, status])
  @@index([openedById])
  @@index([approvedById])
}

// Sales invoice (VAT / Non-VAT). Created when a JO is completed,
// or directly for non-JO transactions (photocopy, laminate, supplies).
model Sale {
  id          String    @id @default(cuid())
  documentNo  String
  bookletId   String?
  booklet     Booklet?  @relation(fields: [bookletId], references: [id])
  type        SaleType
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  jobOrderId  String?   @unique // null → non-JO transaction
  jobOrder    JobOrder? @relation(fields: [jobOrderId], references: [id])
  saleDate    DateTime
  amount      Decimal   @db.Decimal(12, 2)
  vatAmount   Decimal   @default(0) @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String
  createdBy   User      @relation("SaleCreatedBy", fields: [createdById], references: [id])

  auditEntries  AuditEntry[]
  crAllocations CrAllocation[]

  @@index([documentNo])
  @@index([customerId])
  @@index([saleDate])
  @@index([type])
  @@index([deletedAt])
  @@index([bookletId])
  @@index([createdById])
}

model CollectionReceipt {
  id          String        @id @default(cuid())
  crNumber    String        @unique
  bookletId   String?
  booklet     Booklet?      @relation(fields: [bookletId], references: [id])
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  receivedAt  DateTime
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  createdById String
  createdBy   User          @relation("CrCreatedBy", fields: [createdById], references: [id])

  allocations CrAllocation[]

  @@index([customerId])
  @@index([receivedAt])
  @@index([deletedAt])
  @@index([bookletId])
  @@index([createdById])
}

// "No floating CRs" (spec 2.4): every CR must allocate fully to
// specific sales invoices — enforced in the service layer.
model CrAllocation {
  id     String            @id @default(cuid())
  crId   String
  cr     CollectionReceipt @relation(fields: [crId], references: [id], onDelete: Cascade)
  saleId String
  sale   Sale              @relation(fields: [saleId], references: [id])
  amount Decimal           @db.Decimal(12, 2)

  @@unique([crId, saleId])
  @@index([saleId])
}

// Canonical advance-payment entity (spec section 4):
// created in Sales, consumed by the JO approval gate and DR issuance.
model AdvancePayment {
  id          String               @id @default(cuid())
  customerId  String
  customer    Customer             @relation(fields: [customerId], references: [id])
  amount      Decimal              @db.Decimal(12, 2)
  method      PaymentMethod
  status      AdvancePaymentStatus @default(UNAPPLIED)
  reference   String? // OR / deposit slip / GCash ref
  receivedAt  DateTime
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  createdById String
  createdBy   User                 @relation("ApCreatedBy", fields: [createdById], references: [id])

  applications AdvancePaymentApplication[]

  @@index([customerId, status])
  @@index([deletedAt])
  @@index([createdById])
}

model AdvancePaymentApplication {
  id                String           @id @default(cuid())
  advancePaymentId  String
  advancePayment    AdvancePayment   @relation(fields: [advancePaymentId], references: [id], onDelete: Cascade)
  jobOrderId        String?
  jobOrder          JobOrder?        @relation(fields: [jobOrderId], references: [id])
  deliveryReceiptId String?
  deliveryReceipt   DeliveryReceipt? @relation(fields: [deliveryReceiptId], references: [id])
  amount            Decimal          @db.Decimal(12, 2)
  appliedById       String
  appliedBy         User             @relation("ApAppliedBy", fields: [appliedById], references: [id])
  appliedAt         DateTime         @default(now())

  @@index([advancePaymentId])
  @@index([jobOrderId])
  @@index([deliveryReceiptId])
  @@index([appliedById])
}

// ============================================================
// DELIVERY RECEIPTS (new module — spec section 3)
// ============================================================

model DeliveryReceipt {
  id          String                @id @default(cuid())
  drNumber    String                @unique
  bookletId   String?
  booklet     Booklet?              @relation(fields: [bookletId], references: [id])
  jobOrderId  String
  jobOrder    JobOrder              @relation(fields: [jobOrderId], references: [id])
  customerId  String
  customer    Customer              @relation(fields: [customerId], references: [id])
  status      DeliveryReceiptStatus @default(ISSUED)
  issuedAt    DateTime              @default(now())
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?
  createdById String
  createdBy   User                  @relation("DrCreatedBy", fields: [createdById], references: [id])

  lines          DeliveryReceiptLine[]
  apApplications AdvancePaymentApplication[]

  @@index([jobOrderId])
  @@index([customerId])
  @@index([deletedAt])
  @@index([bookletId])
  @@index([createdById])
}

// DR is issued per completed JO line item; partial by quantity (spec 3.2)
model DeliveryReceiptLine {
  id                String          @id @default(cuid())
  deliveryReceiptId String
  deliveryReceipt   DeliveryReceipt @relation(fields: [deliveryReceiptId], references: [id], onDelete: Cascade)
  jobOrderItemId    String
  jobOrderItem      JobOrderItem    @relation(fields: [jobOrderItemId], references: [id])
  qty               Int

  @@index([deliveryReceiptId])
  @@index([jobOrderItemId])
}

// ============================================================
// AUDIT / RECONCILIATION
// ============================================================

model AuditEntry {
  id        String           @id @default(cuid())
  saleId    String
  sale      Sale             @relation(fields: [saleId], references: [id])
  status    AuditEntryStatus
  flagType  AuditFlagType?
  remarks   String?
  auditorId String
  auditor   User             @relation("AuditEntryAuditor", fields: [auditorId], references: [id])
  auditedAt DateTime         @default(now())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([saleId])
  @@index([status])
  @@index([auditorId])
}

// Day-level reconciliation + locking (ported from legacy Sales-Audit)
model ReconciliationDay {
  id            String         @id @default(cuid())
  date          DateTime       @unique @db.Date
  status        ReconDayStatus @default(NOT_STARTED)
  depositAmount Decimal?       @db.Decimal(12, 2)
  depositDate   DateTime?
  remarks       String?
  lockedById    String?
  lockedBy      User?          @relation("ReconLockedBy", fields: [lockedById], references: [id])
  lockedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([lockedById])
}

// ============================================================
// TRACEABILITY
// ============================================================

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  entityType String // "JobOrder", "Quotation", "Sale", ...
  entityId   String
  action     String // "create", "update", "approve", "convert", ...
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// Transactional counters for system-generated numbers (quote/JO)
// — booklet-issued documents use Booklet.nextNumber instead.
model Counter {
  key   String @id
  value Int    @default(0)
}
