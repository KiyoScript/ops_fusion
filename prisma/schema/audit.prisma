// ============================================================
// AUDIT / RECONCILIATION
// ============================================================

enum AuditEntryStatus {
  REVIEWED
  FLAGGED
}

enum AuditFlagType {
  DISCREPANCY
  MISSING
  CANCELLED
}

enum ReconDayStatus {
  NOT_STARTED
  IN_PROGRESS
  FLAGGED
  CLOSED
}

model AuditEntry {
  id        String           @id @default(cuid())
  saleId    String
  sale      Sale             @relation(fields: [saleId], references: [id])
  status    AuditEntryStatus
  flagType  AuditFlagType?
  remarks   String?
  auditorId String
  auditor   User             @relation("AuditEntryAuditor", fields: [auditorId], references: [id])
  auditedAt DateTime         @default(now())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([saleId])
  @@index([status])
  @@index([auditorId])
}

// Day-level reconciliation + locking (ported from legacy Sales-Audit)
model ReconciliationDay {
  id            String         @id @default(cuid())
  date          DateTime       @unique @db.Date
  status        ReconDayStatus @default(NOT_STARTED)
  depositAmount Decimal?       @db.Decimal(12, 2)
  depositDate   DateTime?
  remarks       String?
  lockedById    String?
  lockedBy      User?          @relation("ReconLockedBy", fields: [lockedById], references: [id])
  lockedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([lockedById])
}
