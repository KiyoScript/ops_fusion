// ============================================================
// AUDIT / RECONCILIATION
// ============================================================

enum AuditEntryStatus {
  REVIEWED
  FLAGGED
}

enum AuditFlagType {
  DISCREPANCY
  MISSING
  CANCELLED
}

enum ReconDayStatus {
  NOT_STARTED
  IN_PROGRESS
  FLAGGED
  CLOSED
}

// The auditor's sign-off — the legacy verified_by / verified_at, which the
// sheet stamps on EVERY transaction row. So an entry verifies either a Sale or
// a Collection Receipt: exactly one of the two FKs is set, enforced by a CHECK
// constraint in the migration (Prisma can't express it).
model AuditEntry {
  id                  String             @id @default(cuid())
  saleId              String?
  sale                Sale?              @relation(fields: [saleId], references: [id])
  collectionReceiptId String?
  collectionReceipt   CollectionReceipt? @relation(fields: [collectionReceiptId], references: [id])
  status              AuditEntryStatus
  flagType            AuditFlagType?
  remarks             String?
  auditorId           String
  auditor             User               @relation("AuditEntryAuditor", fields: [auditorId], references: [id])
  auditedAt           DateTime           @default(now())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([saleId])
  @@index([collectionReceiptId])
  @@index([status])
  @@index([auditorId])
}

// Day-level reconciliation + locking (ported from legacy Sales-Audit)
model ReconciliationDay {
  id            String         @id @default(cuid())
  date          DateTime       @unique @db.Date
  status        ReconDayStatus @default(NOT_STARTED)
  depositAmount Decimal?       @db.Decimal(12, 2)
  depositDate   DateTime?
  remarks       String?
  lockedById    String?
  lockedBy      User?          @relation("ReconLockedBy", fields: [lockedById], references: [id])
  lockedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([lockedById])
}
