// ============================================================
// QUOTATIONS (QJOS)
// ============================================================

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

// Legacy quotation_system VAT toggle: every calculator offered Non-VAT,
// VAT added on top (+12%), or VAT backed out of the quoted price.
enum TaxType {
  NON_VAT
  VAT_EXCLUSIVE
  VAT_INCLUSIVE
}

model Quotation {
  id             String          @id @default(cuid())
  quoteNumber    String          @unique
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  status         QuotationStatus @default(DRAFT)
  validUntil     DateTime?
  subtotal       Decimal         @default(0) @db.Decimal(12, 2)
  discount       Decimal         @default(0) @db.Decimal(12, 2)
  taxType        TaxType         @default(NON_VAT)
  taxAmount      Decimal         @default(0) @db.Decimal(12, 2)
  total          Decimal         @default(0) @db.Decimal(12, 2)
  // Legacy payment terms (Payment Terms tab of the price DB): downpayment
  // fraction 0 / 0.25 / 0.5 / 1 — drives downpayment/balance on the printable.
  paymentTermLabel String?
  downpaymentRate  Decimal       @default(0.5) @db.Decimal(3, 2)
  notes          String?
  sentAt         DateTime?
  approvedById   String?
  approvedBy     User?           @relation("QuotationApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  createdById    String
  createdBy      User            @relation("QuotationCreatedBy", fields: [createdById], references: [id])

  items    QuotationItem[]
  jobOrder JobOrder? // 1—0..1 conversion link
  inquiry  Inquiry?

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([approvedById])
  @@index([createdById])
}

// productId is optional (same decision as JobOrderItem): items are free-text
// descriptions until they're linked to the Product catalog / calculators.
model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])
  description String
  specs       Json? // size, material, color, etc. — varies per product type
  qty         Int
  unitPrice   Decimal   @db.Decimal(12, 2)
  discount    Decimal   @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal   @db.Decimal(12, 2)
  sortOrder   Int       @default(0)

  @@index([quotationId])
  @@index([productId])
}
