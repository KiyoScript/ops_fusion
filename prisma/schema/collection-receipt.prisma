// ============================================================
// SALES / AUDIT — COLLECTION RECEIPT
// ============================================================

// Shared by CollectionReceipt and AdvancePayment (advance-payment.prisma).
enum PaymentMethod {
  CASH
  CHECK
  GCASH
  BANK_TRANSFER
  QR
}

model CollectionReceipt {
  id          String        @id @default(cuid())
  crNumber    String        @unique
  bookletId   String?
  booklet     Booklet?      @relation(fields: [bookletId], references: [id])
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  receivedAt  DateTime
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  createdById String
  createdBy   User          @relation("CrCreatedBy", fields: [createdById], references: [id])

  allocations CrAllocation[]

  @@index([customerId])
  @@index([receivedAt])
  @@index([deletedAt])
  @@index([bookletId])
  @@index([createdById])
}

// "No floating CRs" (spec 2.4): every CR must allocate fully to
// specific sales invoices — enforced in the service layer.
model CrAllocation {
  id     String            @id @default(cuid())
  crId   String
  cr     CollectionReceipt @relation(fields: [crId], references: [id], onDelete: Cascade)
  saleId String
  sale   Sale              @relation(fields: [saleId], references: [id])
  amount Decimal           @db.Decimal(12, 2)

  @@unique([crId, saleId])
  @@index([saleId])
}
