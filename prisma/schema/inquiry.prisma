// ============================================================
// QUOTATIONS (QJOS) — INQUIRY
// ============================================================

enum InquiryMedium {
  MESSENGER
  EMAIL
  WALK_IN
  CALL
  VIBER
  PORTAL // anonymous submissions from the public /quote-request page
}

// Inquiry lifecycle: OPEN (logged, no quote yet) → QUOTED (a quotation was
// made from it — set automatically on link) → CLOSED (dropped without a
// quote: no interest, unreachable, spam).
enum InquiryStatus {
  OPEN
  QUOTED
  CLOSED
}

// Spec 1.2 Step 1 — inquiry log (Type A JOs start here)
model Inquiry {
  id                String        @id @default(cuid())
  customerId        String?
  customer          Customer?     @relation(fields: [customerId], references: [id])
  customerName      String
  contactNumber     String?
  email             String?
  medium            InquiryMedium
  status            InquiryStatus @default(OPEN)
  closedReason      String? // why it was closed without a quote
  servicesRequested String
  notes             String?
  quotationId       String?       @unique
  quotation         Quotation?    @relation(fields: [quotationId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdById       String
  createdBy         User          @relation("InquiryCreatedBy", fields: [createdById], references: [id])

  @@index([customerId])
  @@index([medium])
  @@index([status])
  @@index([createdAt])
  @@index([createdById])
}
